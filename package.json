{
  "name": "resync",
  "version": "1.0.0",
  "scripts": {
    "schema:generate": "opam exec -- dune build packages/realtime-schema/src/realtime_schema_codegen_main.exe && opam exec -- ./_build/default/packages/realtime-schema/src/realtime_schema_codegen_main.exe --sql-dir ./demos/ecommerce/server/sql --out-triggers ./demos/ecommerce/server/sql/generated/realtime.sql --out-snapshot ./demos/ecommerce/server/sql/generated/schema_snapshot.json --migrations-dir ./demos/ecommerce/server/sql/generated/migrations",
    "ecommerce:db:init": "pnpm run schema:generate && ./scripts/init-ecommerce-db.sh",
    "ecommerce:dune:watch": "/bin/zsh -i -c 'opam exec -- dune build @ecommerce-app @ecommerce-server --force -w'",
    "ecommerce:serve": "opam exec -- dune exec -w demos/ecommerce/server/src/server.exe",
    "ecommerce:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/ecommerce/ui/src/.build_stamp -r -c -- ./_build/default/demos/ecommerce/server/src/server.exe",
    "todo:dune:watch": "opam exec -- dune build -w @todo-app @todo-server",
    "todo:serve": "opam exec -- dune exec -w demos/todo/server/src/server.exe",
    "todo:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/todo/ui/src/.build_stamp -r -c -- ./_build/default/demos/todo/server/src/server.exe",
    "todo-mp:schema:generate": "opam exec -- dune build packages/realtime-schema/src/realtime_schema_codegen_main.exe && opam exec -- ./_build/default/packages/realtime-schema/src/realtime_schema_codegen_main.exe --sql-dir ./demos/todo-multiplayer/server/sql --out-triggers ./demos/todo-multiplayer/server/sql/generated/realtime.sql --out-snapshot ./demos/todo-multiplayer/server/sql/generated/schema_snapshot.json --migrations-dir ./demos/todo-multiplayer/server/sql/generated/migrations",
    "todo-mp:db:init": "pnpm run todo-mp:schema:generate && ./scripts/init-todo-mp-db.sh",
    "todo-mp:dune:watch": "opam exec -- dune build demos/todo-multiplayer/ui/src/.build_stamp demos/todo-multiplayer/server/src/server.exe --force -w",
    "todo-mp:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/todo-multiplayer/ui/src/.build_stamp -r -c -- ./_build/default/demos/todo-multiplayer/server/src/server.exe",
    "video-chat:dune:watch": "opam exec -- dune build demos/video-chat/ui/src/.build_stamp demos/video-chat/server/src/server.exe --force -w",
    "video-chat:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/video-chat/ui/src/.build_stamp -r -c -- ./_build/default/demos/video-chat/server/src/server.exe",
    "llm-chat:schema:generate": "opam exec -- dune build packages/realtime-schema/src/realtime_schema_codegen_main.exe && opam exec -- ./_build/default/packages/realtime-schema/src/realtime_schema_codegen_main.exe --sql-dir ./demos/llm-chat/server/sql --out-triggers ./demos/llm-chat/server/sql/generated/realtime.sql --out-snapshot ./demos/llm-chat/server/sql/generated/schema_snapshot.json --migrations-dir ./demos/llm-chat/server/sql/generated/migrations",
    "llm-chat:db:init": "pnpm run llm-chat:schema:generate && ./scripts/init-llm-chat-db.sh",
    "llm-chat:dune:watch": "opam exec -- dune build demos/llm-chat/ui/src/.build_stamp demos/llm-chat/server/src/server.exe --force -w",
    "llm-chat:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/llm-chat/ui/src/.build_stamp -r -c -- ./_build/default/demos/llm-chat/server/src/server.exe",
    "todo-mp:test:browser": "opam exec -- dune build --build-dir _build_browser_tests demos/todo-multiplayer/tests/browser/.build_stamp demos/todo-multiplayer/ui/src/.build_stamp demos/todo-multiplayer/server/src/server.exe && node ./demos/todo-multiplayer/tests/browser/generated/TodoMultiplayerBrowserTest.mjs",
    "ecommerce:test:browser": "opam exec -- dune build --build-dir _build_browser_tests demos/ecommerce/tests/browser/.build_stamp demos/ecommerce/ui/src/.build_stamp demos/ecommerce/server/src/server.exe && node ./demos/ecommerce/tests/browser/generated/EcommerceBrowserTest.mjs",
    "video-chat:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @video-chat-browser-tests && node ./demos/video-chat/tests/browser/generated/VideoChatBrowserTest.mjs",
    "llm-chat:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @llm-chat-browser-tests && node ./demos/llm-chat/tests/browser/generated/LlmChatBrowserTest.mjs",
    "llm-chat:test:unit": "DUNE_TIMEOUT=300 python3 scripts/run_dune.py exec packages/reason-realtime/stream/test/stream_test.exe",
    "todo:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @todo-browser-tests && node ./demos/todo/tests/browser/generated/TodoBrowserTest.mjs",
    "router:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @router-browser-tests && node ./packages/universal-reason-react/router/test-browser/generated/RouterBrowserTest.mjs",
    "store:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @store-browser-tests && node ./packages/universal-reason-react/store/test-browser/generated/StoreBrowserTest.mjs",
    "components:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @components-browser-tests && node ./packages/universal-reason-react/components/test-browser/generated/ComponentsBrowserTest.mjs",
    "lucide-icons:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @lucide-icons-browser-tests && node ./packages/universal-reason-react/lucide-icons/test-browser/generated/LucideIconsBrowserTest.mjs",
    "sonner:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @sonner-browser-tests && node ./packages/universal-reason-react/sonner/test-browser/generated/SonnerBrowserTest.mjs",
    "intl:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @intl-browser-tests && node ./packages/universal-reason-react/intl/test-browser/generated/IntlBrowserTest.mjs",
    "framework:test:browser": "opam exec -- dune build --build-dir _build_browser_tests @router-browser-tests @store-browser-tests @components-browser-tests @lucide-icons-browser-tests @sonner-browser-tests @intl-browser-tests @todo-browser-tests @todo-app @todo-server && node ./scripts/run-framework-browser-tests.mjs",
    "dune:watch": "opam exec -- dune build -w",
    "serve": "pnpm run ecommerce:serve",
    "watch": "pnpm run ecommerce:watch"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "streamdown": "^2.5.0",
    "@tilia/react": "5.0.0-beta.20251218T180640",
    "common": "link:demos/ecommerce/shared",
    "ecommerce-ui": "link:demos/ecommerce/ui",
    "lucide-react": "^0.555.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "store-backend": "link:demos/ecommerce/server",
    "tilia": "5.0.0-beta.20251218T180640",
    "uuidv7": "^1.2.1",
    "llm-chat-ui": "link:demos/llm-chat/ui",
    "todo-multiplayer-ui": "link:demos/todo-multiplayer/ui",
    "todo-ui": "link:demos/todo/ui",
    "video-chat-ui": "link:demos/video-chat/ui"
  },
  "overrides": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "esbuild": "^0.27.4",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2"
  }
}

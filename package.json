{
  "name": "resync",
  "version": "1.0.0",
  "scripts": {
    "ecommerce:dune:watch": "/bin/zsh -i -c 'dune build @ecommerce-app @ecommerce-server --force -w'",
    "ecommerce:serve": "dune exec -w demos/ecommerce/server/src/server.exe",
    "ecommerce:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/ecommerce/ui/src/.build_stamp -r -c -- ./_build/default/demos/ecommerce/server/src/server.exe",

    "todo:dune:watch": "/bin/zsh -i -c 'dune build @todo-app @todo-server --force -w'",
    "todo:serve": "dune exec -w demos/todo/server/src/server.exe",
    "todo:watch": "watchexec --no-vcs-ignore -w ./_build/default/demos/todo/ui/src/.build_stamp -r -c -- ./_build/default/demos/todo/server/src/server.exe",

    "dune:watch": "pnpm run ecommerce:dune:watch",
    "serve": "pnpm run ecommerce:serve",
    "watch": "pnpm run ecommerce:watch"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tilia/react": "5.0.0-beta.20251218T180640",
    "common": "link:demos/ecommerce/shared",
    "ecommerce-ui": "link:demos/ecommerce/ui",
    "todo-ui": "link:demos/todo/ui",
    "lucide-react": "^0.555.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "store-backend": "link:demos/ecommerce/server",
    "tilia": "5.0.0-beta.20251218T180640"
  },
  "overrides": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "tailwindcss": "^4.2.2"
  }
}

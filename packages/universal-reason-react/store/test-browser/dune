(library
 (name store_browser_test)
 (modules StoreBrowserTest StoreTestServer)
 (wrapped false)
 (libraries melange.js playwright_js)
 (modes melange)
 (preprocess (pps server-reason-react.ppx -melange server-reason-react.browser_ppx -js melange.ppx)))

(melange.emit
 (target dist)
 (alias store-browser-tests)
 (modules ())
 (module_systems (esm "mjs"))
 (promote (until-clean) (into ./generated))
 (libraries store_browser_test))

(rule
 (targets .build_stamp)
 (deps
  generated/StoreBrowserTest.mjs)
 (action
  (with-stdout-to
   .build_stamp
   (system "date +%s"))))
